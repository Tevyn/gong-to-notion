# Notion internal integration token (workspace-scoped).
# Create at https://www.notion.so/profile/integrations
NOTION_TOKEN=

# Data source ID of the Customer Interactions database.
NOTION_DATABASE_ID=

# Gong API credentials (Company Settings -> API)
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=

# Gong region host for your tenant, e.g. https://us-XXXXX.api.gong.io
GONG_BASE_URL=
